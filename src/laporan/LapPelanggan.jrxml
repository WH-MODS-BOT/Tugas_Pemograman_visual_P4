	<subDataset name="Wahid_pelanggan" uuid="3f90e1cf-f252-47ea-976b-a1e4f3e94300">
		<queryString language="SQL">
			<![CDATA[SELECT
     pelanggan.`id_plgn` AS pelanggan_id_plgn,
     pelanggan.`nm_plgn` AS pelanggan_nm_plgn,
     pelanggan.`jenis` AS pelanggan_jenis,
     pelanggan.`tlpn` AS pelanggan_tlpn,
     pelanggan.`alamat` AS pelanggan_alamat
FROM
     `pelanggan` pelanggan]]>
		</queryString>
